<?xml version="1.0"?>
<config xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:noNamespaceSchemaLocation="urn:magento:framework:Backend/etc/system_file.xsd">
    <system>
        <section id="dominate_erpconnector" translate="label" sortOrder="2" showInDefault="1" showInWebsite="1" showInStore="1">
            <label>Dominate ERP Connector</label>
            <tab>dominate</tab>
            <resource>Dominate_ErpConnector::config</resource>

            <group id="info" translate="label" type="text" sortOrder="10" showInDefault="1" showInWebsite="1" showInStore="1">
                <label>Info</label>
                <field id="version" translate="label" type="text" sortOrder="1" showInDefault="1" showInWebsite="1" showInStore="1">
                    <label>Version</label>
                    <frontend_model>Dominate\ErpConnector\Block\Adminhtml\System\Config\Version</frontend_model>
                </field>
                <field id="documentation" translate="label" type="text" sortOrder="2" showInDefault="1" showInWebsite="1" showInStore="1">
                    <label>Documentation</label>
                    <frontend_model>Dominate\ErpConnector\Block\Adminhtml\System\Config\Documentation</frontend_model>
                </field>
                <field id="register_account" translate="label" type="text" sortOrder="3" showInDefault="1" showInWebsite="1" showInStore="1">
                    <label>Create Dominate Account</label>
                    <frontend_model>Dominate\ErpConnector\Block\Adminhtml\System\Config\Registration</frontend_model>
                </field>
                <field id="support" translate="label" type="text" sortOrder="4" showInDefault="1" showInWebsite="1" showInStore="1">
                    <label>Support</label>
                    <frontend_model>Dominate\ErpConnector\Block\Adminhtml\System\Config\Support</frontend_model>
                </field>
            </group>

            <group id="general" translate="label" type="text" sortOrder="20" showInDefault="1" showInWebsite="1" showInStore="1">
                <label>General</label>
                <field id="enabled" translate="label" type="select" sortOrder="1" showInDefault="1" showInWebsite="1" showInStore="1">
                    <label>Enabled</label>
                    <source_model>Magento\Config\Model\Config\Source\Yesno</source_model>
                </field>
                <field id="api_key" translate="label" type="text" sortOrder="2" showInDefault="1" showInWebsite="1" showInStore="1">
                    <label>API Key</label>
                    <depends>
                        <field id="enabled">1</field>
                    </depends>
                </field>
                <field id="api_secret" translate="label" type="obscure" sortOrder="3" showInDefault="1" showInWebsite="1" showInStore="1">
                    <label>API Secret</label>
                    <backend_model>Magento\Config\Model\Config\Backend\Encrypted</backend_model>
                    <depends>
                        <field id="enabled">1</field>
                    </depends>
                </field>
                <field id="connection_status" translate="label" type="text" sortOrder="4" showInDefault="1" showInWebsite="1" showInStore="1">
                    <label>Connection Status</label>
                    <frontend_model>Dominate\ErpConnector\Block\Adminhtml\System\Config\ConnectionStatus</frontend_model>
                </field>
                <field id="dashboard" translate="label" type="button" sortOrder="5" showInDefault="1" showInWebsite="1" showInStore="1">
                    <label>Account Dashboard</label>
                    <frontend_model>Dominate\ErpConnector\Block\Adminhtml\System\Config\Dashboard</frontend_model>
                </field>
            </group>
        </section>
    </system>
</config>
