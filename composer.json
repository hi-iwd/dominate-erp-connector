{
  "name": "iwd/dominate-erp-connector",
  "description": "Dominate ERP Connector for Magento 2",
  "type": "magento2-module",
  "version": "1.0.0",
  "license": [
    "proprietary"
  ],
  "autoload": {
    "files": [
      "registration.php"
    ],
    "psr-4": {
      "Dominate\\ErpConnector\\": ""
    }
